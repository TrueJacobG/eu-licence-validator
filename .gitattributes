# Default: normalize text files to LF in the repo, native on checkout.
* text=auto eol=lf

# Explicitly text.
*.go         text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.py         text eol=lf
*.rb         text eol=lf
*.java       text eol=lf
*.json       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.md         text eol=lf
Makefile     text eol=lf
go.mod       text eol=lf
go.sum       text eol=lf

# Generated binaries — never diff/merge as text.
*.wasm       binary
*.png        binary
*.jpg        binary
*.ico        binary
*.zip        binary
*.tgz        binary

# Treat the WASM build output as binary (also gitignored, but keep it safe).
core/core.wasm                 binary
bindings/*/wasm/core.wasm      binary
