{
  "name": "@truejacobg/eu-licence-validator",
  "version": "0.0.0",
  "description": "European licence plate validation. Single Go core compiled to WebAssembly, bundled for Node.js.",
  "license": "MIT",
  "author": "TrueJacobG",
  "homepage": "https://github.com/TrueJacobG/eu-licence-validator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TrueJacobG/eu-licence-validator.git",
    "directory": "bindings/node"
  },
  "bugs": {
    "url": "https://github.com/TrueJacobG/eu-licence-validator/issues"
  },
  "keywords": [
    "licence",
    "license",
    "plate",
    "european",
    "eu",
    "validation",
    "wasm"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "wasm/core.wasm"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^7.0.2"
  }
}
